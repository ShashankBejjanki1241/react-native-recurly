# Clerk — Dashboard → API keys → Publishable key
# https://clerk.com/docs/quickstarts/expo
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Optional: if you already use Next.js env names locally, this is also read:
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Server-only (never ship in the mobile app) — for a future API / web backend:
# CLERK_SECRET_KEY=sk_test_...
